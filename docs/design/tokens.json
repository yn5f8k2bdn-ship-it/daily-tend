{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "Wellness Works design tokens. Fallback palette used on Android <12 and iOS; see material_you.md for dynamic-colour mapping on Android 12+.",
  "color": {
    "light": {
      "neutral": {
        "bg":                 { "$value": "#F7F2EC", "$type": "color" },
        "surface":            { "$value": "#FFFBF5", "$type": "color" },
        "surfaceElevated":    { "$value": "#FFFFFF", "$type": "color" },
        "onSurface":          { "$value": "#1F1B16", "$type": "color" },
        "onSurfaceSecondary": { "$value": "#5A534B", "$type": "color" },
        "onSurfaceTertiary":  { "$value": "#8A8079", "$type": "color" },
        "divider":            { "$value": "#E6DED3", "$type": "color" },
        "overlay":            { "$value": "#1F1B1640", "$type": "color" }
      },
      "primary": {
        "base":               { "$value": "#D9A04C", "$type": "color" },
        "on":                 { "$value": "#2E1F0E", "$type": "color" },
        "container":          { "$value": "#FBE5C7", "$type": "color" },
        "onContainer":        { "$value": "#4A2F0E", "$type": "color" }
      },
      "secondary": {
        "base":               { "$value": "#2E6B73", "$type": "color" },
        "on":                 { "$value": "#FFFFFF", "$type": "color" },
        "container":          { "$value": "#C2DBDD", "$type": "color" },
        "onContainer":        { "$value": "#0E2F33", "$type": "color" }
      },
      "semantic": {
        "success":            { "$value": "#5C8A5E", "$type": "color" },
        "warning":            { "$value": "#C99A3D", "$type": "color" },
        "error":              { "$value": "#B4544A", "$type": "color" },
        "info":               { "$value": "#5E7E99", "$type": "color" }
      },
      "zone": {
        "self":               { "$value": "#6B8FA8", "$type": "color" },
        "selfContainer":      { "$value": "#D8E4EE", "$type": "color" },
        "purpose":            { "$value": "#B8864A", "$type": "color" },
        "purposeContainer":   { "$value": "#EEDFC7", "$type": "color" },
        "lovedOnes":          { "$value": "#A8678A", "$type": "color" },
        "lovedOnesContainer": { "$value": "#EAD4DF", "$type": "color" }
      }
    },
    "dark": {
      "neutral": {
        "bg":                 { "$value": "#1A1714", "$type": "color" },
        "surface":            { "$value": "#221E1A", "$type": "color" },
        "surfaceElevated":    { "$value": "#2C2722", "$type": "color" },
        "onSurface":          { "$value": "#F1EAE0", "$type": "color" },
        "onSurfaceSecondary": { "$value": "#BDB3A6", "$type": "color" },
        "onSurfaceTertiary":  { "$value": "#877E72", "$type": "color" },
        "divider":            { "$value": "#38322C", "$type": "color" },
        "overlay":            { "$value": "#00000066", "$type": "color" }
      },
      "primary": {
        "base":               { "$value": "#E8B86E", "$type": "color" },
        "on":                 { "$value": "#2E1F0E", "$type": "color" },
        "container":          { "$value": "#5C4220", "$type": "color" },
        "onContainer":        { "$value": "#FBE5C7", "$type": "color" }
      },
      "secondary": {
        "base":               { "$value": "#7FB5BC", "$type": "color" },
        "on":                 { "$value": "#0E2F33", "$type": "color" },
        "container":          { "$value": "#1A4F58", "$type": "color" },
        "onContainer":        { "$value": "#C2DBDD", "$type": "color" }
      },
      "semantic": {
        "success":            { "$value": "#9AC49B", "$type": "color" },
        "warning":            { "$value": "#E6BE7A", "$type": "color" },
        "error":              { "$value": "#E09189", "$type": "color" },
        "info":               { "$value": "#9BB4C9", "$type": "color" }
      },
      "zone": {
        "self":               { "$value": "#A8C2D6", "$type": "color" },
        "selfContainer":      { "$value": "#2E404E", "$type": "color" },
        "purpose":            { "$value": "#E2BA82", "$type": "color" },
        "purposeContainer":   { "$value": "#4E3B22", "$type": "color" },
        "lovedOnes":          { "$value": "#D9A7BC", "$type": "color" },
        "lovedOnesContainer": { "$value": "#4A2E3C", "$type": "color" }
      }
    }
  },
  "typography": {
    "fontFamily": {
      "primary":              { "$value": "Inter", "$type": "fontFamily" }
    },
    "scale": {
      "displayLarge":   { "$type": "typography", "$value": { "fontFamily": "Inter", "fontWeight": 500, "fontSize": "40sp", "lineHeight": "48sp", "letterSpacing": "-0.25" } },
      "displayMedium":  { "$type": "typography", "$value": { "fontFamily": "Inter", "fontWeight": 500, "fontSize": "32sp", "lineHeight": "40sp", "letterSpacing": "0" } },
      "headlineLarge":  { "$type": "typography", "$value": { "fontFamily": "Inter", "fontWeight": 600, "fontSize": "28sp", "lineHeight": "36sp", "letterSpacing": "0" } },
      "headlineMedium": { "$type": "typography", "$value": { "fontFamily": "Inter", "fontWeight": 600, "fontSize": "24sp", "lineHeight": "32sp", "letterSpacing": "0" } },
      "headlineSmall":  { "$type": "typography", "$value": { "fontFamily": "Inter", "fontWeight": 600, "fontSize": "20sp", "lineHeight": "28sp", "letterSpacing": "0" } },
      "titleLarge":     { "$type": "typography", "$value": { "fontFamily": "Inter", "fontWeight": 600, "fontSize": "18sp", "lineHeight": "26sp", "letterSpacing": "0" } },
      "titleMedium":    { "$type": "typography", "$value": { "fontFamily": "Inter", "fontWeight": 600, "fontSize": "16sp", "lineHeight": "24sp", "letterSpacing": "0.1" } },
      "titleSmall":     { "$type": "typography", "$value": { "fontFamily": "Inter", "fontWeight": 600, "fontSize": "14sp", "lineHeight": "20sp", "letterSpacing": "0.1" } },
      "bodyLarge":      { "$type": "typography", "$value": { "fontFamily": "Inter", "fontWeight": 400, "fontSize": "17sp", "lineHeight": "26sp", "letterSpacing": "0.15" } },
      "bodyMedium":     { "$type": "typography", "$value": { "fontFamily": "Inter", "fontWeight": 400, "fontSize": "15sp", "lineHeight": "22sp", "letterSpacing": "0.2" } },
      "bodySmall":      { "$type": "typography", "$value": { "fontFamily": "Inter", "fontWeight": 400, "fontSize": "13sp", "lineHeight": "18sp", "letterSpacing": "0.25" } },
      "labelLarge":     { "$type": "typography", "$value": { "fontFamily": "Inter", "fontWeight": 600, "fontSize": "15sp", "lineHeight": "20sp", "letterSpacing": "0.1" } },
      "labelMedium":    { "$type": "typography", "$value": { "fontFamily": "Inter", "fontWeight": 600, "fontSize": "13sp", "lineHeight": "16sp", "letterSpacing": "0.4" } },
      "labelSmall":     { "$type": "typography", "$value": { "fontFamily": "Inter", "fontWeight": 600, "fontSize": "11sp", "lineHeight": "14sp", "letterSpacing": "0.5" } }
    }
  },
  "spacing": {
    "base":  { "$value": "4dp",  "$type": "dimension" },
    "xs":    { "$value": "4dp",  "$type": "dimension" },
    "sm":    { "$value": "8dp",  "$type": "dimension" },
    "md":    { "$value": "12dp", "$type": "dimension" },
    "lg":    { "$value": "16dp", "$type": "dimension" },
    "xl":    { "$value": "24dp", "$type": "dimension" },
    "xxl":   { "$value": "32dp", "$type": "dimension" },
    "xxxl":  { "$value": "48dp", "$type": "dimension" },
    "huge":  { "$value": "64dp", "$type": "dimension" }
  },
  "radius": {
    "xs":    { "$value": "8dp",    "$type": "dimension" },
    "sm":    { "$value": "12dp",   "$type": "dimension" },
    "md":    { "$value": "16dp",   "$type": "dimension" },
    "lg":    { "$value": "24dp",   "$type": "dimension" },
    "xl":    { "$value": "32dp",   "$type": "dimension" },
    "full":  { "$value": "9999dp", "$type": "dimension" }
  },
  "elevation": {
    "style": "tonal",
    "level0": { "$type": "elevation", "$value": { "tonalTintLight": "0%",  "tonalTintDark": "0%",  "shadow": "none" } },
    "level1": { "$type": "elevation", "$value": { "tonalTintLight": "3%",  "tonalTintDark": "5%",  "shadow": "none" } },
    "level2": { "$type": "elevation", "$value": { "tonalTintLight": "5%",  "tonalTintDark": "8%",  "shadow": "0 1 2 rgba(0,0,0,0.08)" } },
    "level3": { "$type": "elevation", "$value": { "tonalTintLight": "8%",  "tonalTintDark": "11%", "shadow": "0 2 6 rgba(0,0,0,0.10)" } },
    "level4": { "$type": "elevation", "$value": { "tonalTintLight": "11%", "tonalTintDark": "14%", "shadow": "0 4 10 rgba(0,0,0,0.12)" } },
    "level5": { "$type": "elevation", "$value": { "tonalTintLight": "14%", "tonalTintDark": "17%", "shadow": "0 6 14 rgba(0,0,0,0.14)" } }
  },
  "motion": {
    "duration": {
      "short":  { "$value": "120ms", "$type": "duration" },
      "medium": { "$value": "240ms", "$type": "duration" },
      "long":   { "$value": "360ms", "$type": "duration" },
      "xlong":  { "$value": "520ms", "$type": "duration" }
    },
    "easing": {
      "standard":           { "$value": "cubic-bezier(0.2, 0.0, 0.0, 1.0)",  "$type": "cubicBezier" },
      "standardDecelerate": { "$value": "cubic-bezier(0.0, 0.0, 0.0, 1.0)",  "$type": "cubicBezier" },
      "standardAccelerate": { "$value": "cubic-bezier(0.3, 0.0, 1.0, 1.0)",  "$type": "cubicBezier" },
      "emphasized":         { "$value": "cubic-bezier(0.2, 0.0, 0.0, 1.0)",  "$type": "cubicBezier" }
    },
    "reducedMotion": {
      "replaceWith":        { "$value": "crossFade",  "$type": "string" },
      "duration":           { "$value": "120ms",      "$type": "duration" }
    }
  },
  "tapTarget": {
    "minimum":               { "$value": "48dp", "$type": "dimension" }
  },
  "breakpoint": {
    "phone":                 { "$value": "0dp",   "$type": "dimension" },
    "tabletSmall":           { "$value": "600dp", "$type": "dimension" },
    "tabletLarge":           { "$value": "840dp", "$type": "dimension" }
  },
  "dynamicColour": {
    "$description": "See material_you.md. Lists which token paths are replaced by Material You on Android 12+.",
    "adopts": [
      "color.*.neutral.*",
      "color.*.primary.*",
      "color.*.secondary.*"
    ],
    "frozen": [
      "color.*.zone.*",
      "color.*.semantic.*"
    ]
  }
}
